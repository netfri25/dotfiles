# let everyone on discord know that I use Kakoune
plug "thacuber2a03/kakoune-discord" do %{ cargo install --path . --force } %{
    discord-presence-enable
}


# clipboard
define-command -docstring "get system clipboard" \
clip-get %{ set-register dquote %sh{ wl-paste -n } }

define-command -docstring "set system clipboard" \
clip-copy %{ execute-keys %{<esc><a-|>wl-copy -n<ret>} }

declare-user-mode environment
map global user        e -docstring "enter environment mode" %{<esc>: enter-user-mode environment<ret>}
map global environment c -docstring "copy selection to environment clipboard" %{<esc>: clip-copy<ret>}
map global environment p -docstring "set default register to environment clipboard" %{<esc>: clip-get<ret>}


# spell (requires aspell program)
declare-user-mode spell
map global user  s -docstring "enter spell mode" %{<esc>: enter-user-mode spell<ret>}
map global spell s -docstring "spell replace word" %{<esc>: spell-replace<ret>}
map global spell a -docstring "spell add word to dictionary" %{<esc>: spell-add<ret>}
map global spell o -docstring "spell check entire buffer" %{<esc>: spell<ret>}
map global spell c -docstring "spell check clear" %{<esc>: spell-clear<ret>}
map global spell n -docstring "spell next" %{<esc>: spell-next<ret>}
map global spell p -docstring "spell previous" %{<esc>: spell-prev<ret>}


# operator highlighting
hook -group operator-highlight global WinCreate .* %{
    add-highlighter -override window/operator regex '[-+*/|&%^$@!~#,.?=<>:;{}()[\]]' 0:operator
}


# auto indent rules
hook global -group keep-indent-custom InsertChar \n %{
    # preserve previous line indent
    try %{ execute-keys -draft <semicolon> K <a-&> }
    # cleanup trailing whitespaces from previous line
    try %{ execute-keys -draft k x s \h+$ <ret> d }
}


set-option global disabled_hooks '.*-(indent|insert)'
